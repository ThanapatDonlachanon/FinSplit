generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  username        String
  emoji           String    @default("😊")
  apiToken        String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wallets         Wallet[] @relation("userWallets")
  categories      Category[] @relation("userCategories")
  transactions    Transaction[]
  budgets         Budget[]
  sessions        Session[]
  linkedAccounts  LinkedAccount[]
  memberLinks     Member[]  @relation("memberLinks")
}

model LinkedAccount {
  id        String   @id @default(cuid())
  provider  String   // "line" or "google"
  providerUserId String
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, provider])
}

model Wallet {
  id        String    @id @default(cuid())
  name      String
  icon      String
  color     String
  balance   Float     @default(0)
  currency  String    @default("THB")
  userId    String
  user      User      @relation("userWallets", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  transactions    Transaction[]
  transfersTo     Transaction[] @relation("toWallet")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  icon      String
  color     String
  type      String    // "expense", "income", or "both"
  userId    String
  user      User      @relation("userCategories", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // "expense", "income", or "transfer"
  amount      Float
  note        String?
  date        DateTime
  status      String   @default("confirmed") // "draft" or "confirmed"

  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  toWalletId  String?
  toWallet    Wallet?  @relation("toWallet", fields: [toWalletId], references: [id], onDelete: SetNull)

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Budget {
  id        String    @id @default(cuid())
  limit     Float
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id        String    @id @default(cuid())
  name      String
  emoji     String
  color     String
  currency  String    @default("THB")
  status    String    @default("active") // "active", "settling", or "closed"
  shareToken String   @unique

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  members   Member[]
  bills     Bill[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Member {
  id        String    @id @default(cuid())
  name      String
  color     String
  isMe      Boolean   @default(false)

  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  billShares BillShare[]

  linkedUserId String?
  linkedUser   User?   @relation("memberLinks", fields: [linkedUserId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
}

model Bill {
  id        String    @id @default(cuid())
  name      String
  icon      String
  color     String
  total     Float
  mode      String    // "equal", "item", or "custom"

  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  shares    BillShare[]
  items     BillItem[]

  paidBy    String    @default("")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model BillShare {
  id        String   @id @default(cuid())
  amount    Float

  billId    String
  bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([billId, memberId])
}

model BillItem {
  id        String   @id @default(cuid())
  name      String
  price     Float

  billId    String
  bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  sharers   String[] // array of member IDs

  createdAt DateTime @default(now())
}
